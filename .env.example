# ---- 公司文件浏览器 配置 ----
# 请将本文件复制为 ".env"，然后填写你的实际配置。

# Web 应用监听的端口
PORT=3000

# 要对外提供浏览的文件根目录。用户只能访问此目录及其子目录。
# 对于 Windows SMB 共享，请使用 UNC 路径，例如：
#   SHARE_ROOT=\\fileserver\shared
# 也可以使用本地文件夹（便于测试），例如：
#   SHARE_ROOT=C:\working
SHARE_ROOT=\\fileserver\shared

# 用于签名登录 Cookie 的一长串随机字符串。务必修改此项。
# 可用以下命令生成：
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# 登录的有效时长（小时）
SESSION_HOURS=12

# ---- HTTPS / TLS ----
# 默认即以 HTTPS 提供服务。若未指定证书，首次启动会自动生成自签名证书
# （保存在 data/tls/，重启后复用）。浏览器会对自签名证书提示风险，确认后即可使用。
#
# 生产环境建议使用受信任的证书：取消下面两行注释并填写 PEM 文件路径。
#   TLS_CERT_FILE=C:\path\to\fullchain.pem
#   TLS_KEY_FILE=C:\path\to\privkey.pem
#
# 自签名证书默认只覆盖 localhost / 127.0.0.1。如果客户端通过局域网 IP 或主机名
# 访问，请在此列出这些名称（逗号分隔），证书会自动包含它们，避免“名称不匹配”警告。
# 修改本项后，证书会在下次启动时自动重新生成。
#   TLS_HOSTS=files.corp.local,192.168.1.50
#
# 可选：在该端口上启动一个 HTTP 监听，自动 301 跳转到 HTTPS（例如设为 80）。
#   HTTP_REDIRECT_PORT=80
#
# 如果由前置反向代理（IIS / Nginx）负责 TLS，应用本身改用 HTTP，则设为 true：
#   TLS_DISABLE=true
