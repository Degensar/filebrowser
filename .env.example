# ---- 公司文件浏览器 配置 ----
# 请将本文件复制为 ".env"，然后填写你的实际配置。

# Web 应用监听的端口
PORT=3000

# 要对外提供浏览的文件根目录。用户只能访问此目录及其子目录。
# 对于 Windows SMB 共享，请使用 UNC 路径，例如：
#   SHARE_ROOT=\\fileserver\shared
# 也可以使用本地文件夹（便于测试），例如：
#   SHARE_ROOT=C:\working
SHARE_ROOT=\\fileserver\shared

# 用于签名登录 Cookie 的一长串随机字符串。务必修改此项。
# 可用以下命令生成：
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# 登录的有效时长（小时）
SESSION_HOURS=12

# ---- 审计日志轮转 ----
# 审计日志 data/audit.log 超过该大小（MB）后会自动轮转为 audit.log.1、.2…… 。
# 设为 0 可关闭大小限制（日志将无限增长）。默认 10。
AUDIT_MAX_SIZE_MB=10
# 保留多少个轮转归档（audit.log.1 … audit.log.N）。0 表示不保留历史，仅清空。
# 占用磁盘上限约为 AUDIT_MAX_SIZE_MB ×（AUDIT_MAX_FILES + 1）。默认 5。
AUDIT_MAX_FILES=5

# 仅在应用本身通过 HTTPS 提供服务（或位于负责 TLS 的反向代理之后）时设为 "true"。
# 应用默认以 HTTP 提供服务，因此登录 Cookie 默认不带 Secure 标记。
SECURE_COOKIES=false
