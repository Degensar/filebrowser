# ---- 公司文件浏览器 配置 ----
# 请将本文件复制为 ".env"，然后填写你的实际配置。

# Web 应用监听的端口
PORT=3000

# 要对外提供浏览的文件根目录。用户只能访问此目录及其子目录。
# 对于 Windows SMB 共享，请使用 UNC 路径，例如：
#   SHARE_ROOT=\\fileserver\shared
# 也可以使用本地文件夹（便于测试），例如：
#   SHARE_ROOT=C:\working
SHARE_ROOT=\\fileserver\shared

# 用于签名登录 Cookie 的一长串随机字符串。务必修改此项。
# 可用以下命令生成：
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# 登录的有效时长（小时）
SESSION_HOURS=12

# 仅在通过 HTTPS 提供服务时设为 "true"（生产环境推荐）
SECURE_COOKIES=false
